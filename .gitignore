# =========================
# OS / editor
# =========================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# =========================
# Quarto / render artifacts (default: ignore)
# =========================
.quarto/
_freeze/
_site/
_book/
*_cache/
*_files/

# --- BUT: allow publishing rendered outputs in docs/ ---
!docs/
!docs/**/
!docs/**/*_files/
!docs/**/*_files/**

# (optional but common) allow rendered html in docs/
!docs/**/*.html
!docs/**/*.css
!docs/**/*.js
!docs/**/*.map
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.jpeg
!docs/**/*.gif
!docs/**/*.svg
!docs/**/*.woff
!docs/**/*.woff2
!docs/**/*.ttf
!docs/**/*.eot
!docs/**/*.ico
!docs/**/*.pdf

# =========================
# Jupyter / IPython
# =========================
.ipynb_checkpoints/
.profile_default/

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*.so
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
ENV/
env/

# =========================
# R / RStudio
# =========================
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# =========================
# Cloned source + outputs
# =========================
vendor/
data/
logs/

# =========================
# Large datasets / binaries
# (recommended: download during docker build)
# =========================
*.h5ad
*.h5
*.hdf5
*.loom
*.mtx
*.pkl
*.pickle
*.feather
*.parquet